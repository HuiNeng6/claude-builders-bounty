{
  "name": "Weekly GitHub Summary",
  "nodes": [
    {
      "name": "Weekly Cron Trigger",
      "type": "n8n-nodes-base.cron",
      "position": [250, 300],
      "parameters": {
        "triggerTimes": {
          "item": [
            {
              "mode": "everyWeek",
              "hour": 17,
              "minute": 0,
              "weekday": 5
            }
          ]
        }
      }
    },
    {
      "name": "Set Variables",
      "type": "n8n-nodes-base.set",
      "position": [450, 300],
      "parameters": {
        "values": {
          "string": [
            {
              "name": "repo",
              "value": "claude-builders-bounty/claude-builders-bounty"
            },
            {
              "name": "language",
              "value": "EN"
            },
            {
              "name": "webhookUrl",
              "value": "https://discord.com/api/webhooks/YOUR_WEBHOOK"
            }
          ]
        }
      }
    },
    {
      "name": "Get Commits",
      "type": "n8n-nodes-base.httpRequest",
      "position": [650, 200],
      "parameters": {
        "url": "https://api.github.com/repos/{{$node['Set Variables'].json['repo']}}/commits",
        "authentication": "genericCredentialType",
        "genericAuthCredentials": {
          "token": "YOUR_GITHUB_TOKEN"
        },
        "queryParameters": {
          "parameters": [
            {
              "name": "since",
              "value": "={{new Date(Date.now() - 7*24*60*60*1000).toISOString()}}"
            }
          ]
        },
        "options": {
          "response": {
            "response": {
              "responseFormat": "json"
            }
          }
        }
      }
    },
    {
      "name": "Get Closed Issues",
      "type": "n8n-nodes-base.httpRequest",
      "position": [650, 400],
      "parameters": {
        "url": "https://api.github.com/repos/{{$node['Set Variables'].json['repo']}}/issues",
        "authentication": "genericCredentialType",
        "genericAuthCredentials": {
          "token": "YOUR_GITHUB_TOKEN"
        },
        "queryParameters": {
          "parameters": [
            {
              "name": "state",
              "value": "closed"
            },
            {
              "name": "since",
              "value": "={{new Date(Date.now() - 7*24*60*60*1000).toISOString()}}"
            }
          ]
        }
      }
    },
    {
      "name": "Get Merged PRs",
      "type": "n8n-nodes-base.httpRequest",
      "position": [650, 600],
      "parameters": {
        "url": "https://api.github.com/repos/{{$node['Set Variables'].json['repo']}}/pulls",
        "authentication": "genericCredentialType",
        "genericAuthCredentials": {
          "token": "YOUR_GITHUB_TOKEN"
        },
        "queryParameters": {
          "parameters": [
            {
              "name": "state",
              "value": "closed"
            }
          ]
        }
      }
    },
    {
      "name": "Merge Data",
      "type": "n8n-nodes-base.merge",
      "position": [850, 400],
      "parameters": {
        "mode": "multiplex"
      }
    },
    {
      "name": "Claude Summary",
      "type": "n8n-nodes-base.httpRequest",
      "position": [1050, 400],
      "parameters": {
        "url": "https://api.anthropic.com/v1/messages",
        "authentication": "genericCredentialType",
        "genericAuthCredentials": {
          "token": "YOUR_ANTHROPIC_KEY"
        },
        "headerParameters": {
          "parameters": [
            {
              "name": "anthropic-version",
              "value": "2023-06-01"
            }
          ]
        },
        "bodyParameters": {
          "parameters": [
            {
              "name": "model",
              "value": "claude-sonnet-4-20250514"
            },
            {
              "name": "max_tokens",
              "value": 1024
            },
            {
              "name": "messages",
              "value": "=[{\"role\":\"user\",\"content\":\"Generate a weekly narrative summary in {{$node['Set Variables'].json['language']}} for this GitHub repo activity:\\n\\nCommits: {{$node['Get Commits'].json}}\\n\\nClosed Issues: {{$node['Get Closed Issues'].json}}\\n\\nMerged PRs: {{$node['Get Merged PRs'].json}}\\n\\nFormat as a Discord-friendly message with bullet points and highlights.\"}]"
            }
          ]
        }
      }
    },
    {
      "name": "Send to Discord",
      "type": "n8n-nodes-base.httpRequest",
      "position": [1250, 400],
      "parameters": {
        "url": "{{$node['Set Variables'].json['webhookUrl']}}",
        "method": "POST",
        "bodyParameters": {
          "parameters": [
            {
              "name": "content",
              "value": "={{$node['Claude Summary'].json['content'][0]['text']}}"
            }
          ]
        }
      }
    }
  ],
  "connections": {
    "Weekly Cron Trigger": {
      "main": [
        [
          {
            "node": "Set Variables",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "Set Variables": {
      "main": [
        [
          {
            "node": "Get Commits",
            "type": "main",
            "index": 0
          },
          {
            "node": "Get Closed Issues",
            "type": "main",
            "index": 0
          },
          {
            "node": "Get Merged PRs",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "Get Commits": {
      "main": [
        [
          {
            "node": "Merge Data",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "Get Closed Issues": {
      "main": [
        [
          {
            "node": "Merge Data",
            "type": "main",
            "index": 1
          }
        ]
      ]
    },
    "Get Merged PRs": {
      "main": [
        [
          {
            "node": "Merge Data",
            "type": "main",
            "index": 2
          }
        ]
      ]
    },
    "Merge Data": {
      "main": [
        [
          {
            "node": "Claude Summary",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "Claude Summary": {
      "main": [
        [
          {
            "node": "Send to Discord",
            "type": "main",
            "index": 0
          }
        ]
      ]
    }
  }
}